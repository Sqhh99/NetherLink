        "QPushButton {"
        "   background-color: transparent;"
        "   border: none;"
        "   border-radius: 15px;"
        "}"
        "QPushButton:hover {"
        "   background-color: #e74c3c;"
        "}";
    
    int btnSize = 30;
    
    // 置顶按钮
    btn_pin_ = new QPushButton(title_bar_);
    btn_pin_->setIcon(QIcon(":/icon/zhiding.png"));
    btn_pin_->setIconSize(QSize(16, 16));
    btn_pin_->setFixedSize(btnSize, btnSize);
    btn_pin_->setStyleSheet(btnStyle);
    btn_pin_->setCursor(Qt::PointingHandCursor);
    btn_pin_->setToolTip("置顶");
    connect(btn_pin_, &QPushButton::clicked, this, [this]() {
        is_pinned_ = !is_pinned_;
        if (is_pinned_) {
            setWindowFlags(windowFlags() | Qt::WindowStaysOnTopHint);
            btn_pin_->setIcon(QIcon(":/icon/yizhiding.png"));
            btn_pin_->setToolTip("取消置顶");
        } else {
            setWindowFlags(windowFlags() & ~Qt::WindowStaysOnTopHint);
            btn_pin_->setIcon(QIcon(":/icon/zhiding.png"));
            btn_pin_->setToolTip("置顶");
        }
        show();  // 重新显示窗口（因为改变窗口标志会隐藏窗口）
    });
    title_layout->addWidget(btn_pin_);
    
    // 最小化按钮
    btn_minimize_ = new QPushButton(title_bar_);
    btn_minimize_->setIcon(QIcon(":/icon/minimize.png"));
    btn_minimize_->setIconSize(QSize(16, 16));
    btn_minimize_->setFixedSize(btnSize, btnSize);
    btn_minimize_->setStyleSheet(btnStyle);
    btn_minimize_->setCursor(Qt::PointingHandCursor);
    btn_minimize_->setToolTip("最小化");
    connect(btn_minimize_, &QPushButton::clicked, this, &QWidget::showMinimized);
    title_layout->addWidget(btn_minimize_);
    
    // 最大化按钮
    btn_maximize_ = new QPushButton(title_bar_);
    btn_maximize_->setIcon(QIcon(":/icon/maximize.png"));
    btn_maximize_->setIconSize(QSize(16, 16));
    btn_maximize_->setFixedSize(btnSize, btnSize);
    btn_maximize_->setStyleSheet(btnStyle);
    btn_maximize_->setCursor(Qt::PointingHandCursor);
    btn_maximize_->setToolTip("最大化");
    connect(btn_maximize_, &QPushButton::clicked, this, [this]() {
        if (isMaximized()) {
            showNormal();
        } else {
            showMaximized();
        }
    });
    title_layout->addWidget(btn_maximize_);
    
    // 关闭按钮
    btn_close_ = new QPushButton(title_bar_);
    btn_close_->setIcon(QIcon(":/icon/close.png"));
    btn_close_->setIconSize(QSize(16, 16));
    btn_close_->setFixedSize(btnSize, btnSize);
    btn_close_->setStyleSheet(closeBtnStyle);
    btn_close_->setCursor(Qt::PointingHandCursor);
    btn_close_->setToolTip("关闭");
    connect(btn_close_, &QPushButton::clicked, this, &QWidget::close);
    title_layout->addWidget(btn_close_);
}

void VideoCallDialog::updateCallTime() {
    if (call_state_ != CallState::Connected) {
        return;
    }
    
    int elapsed_seconds = call_start_time_.secsTo(QTime::currentTime());
    int minutes = elapsed_seconds / 60;
    int seconds = elapsed_seconds % 60;
    
    call_time_label_->setText(QString("%1:%2")
        .arg(minutes, 2, 10, QChar('0'))
        .arg(seconds, 2, 10, QChar('0')));
}
